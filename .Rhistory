mutate(entity = ifelse(entity == "Ciudad de México", "Distrito Federal", entity)) %>%
select(Entidad = entity, surface_entity)#, num_anp
#glimpse(data_mexico)
data_mexico$hover_text <- paste("<b>",data_mexico$Entidad,"</b>",

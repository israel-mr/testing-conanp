nuevocorte = read_excel("restauration/3ercorte-restauration200225.xlsx")
actividades_validas = c("Restauración ecológica","Rehabilitación","Regeneración natural",
"Restauración productiva", "Remediación", "Reforestación",
"Ninguna"
)
nuevocorte = nuevocorte %>%
mutate(
ACTIVIDADES = sapply(actividades00, function(actividad){
actividades = unlist(strsplit(actividad, ";"))
actividades = trimws(actividades)
act_validas_encontradas = actividades[actividades %in% actividades_validas]
act_invalidas = actividades[!actividades %in% actividades_validas]
resultado = c(act_validas_encontradas,
if(length(act_invalidas)>0) "Otro")
paste(resultado, collapse = ", ")
}),
otra.act = ifelse(grepl("Otro",ACTIVIDADES),1,0)
)
names(nuevocorte)
nuevocorte = nuevocorte %>%
mutate(
ACTIVIDADES = sapply(actividadesrest, function(actividad){
actividades = unlist(strsplit(actividad, ";"))
actividades = trimws(actividades)
act_validas_encontradas = actividades[actividades %in% actividades_validas]
act_invalidas = actividades[!actividades %in% actividades_validas]
resultado = c(act_validas_encontradas,
if(length(act_invalidas)>0) "Otro")
paste(resultado, collapse = ", ")
}),
otra.act = ifelse(grepl("Otro",ACTIVIDADES),1,0)
)
View(nuevocorte)
